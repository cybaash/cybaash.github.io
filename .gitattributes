# .gitattributes — line endings + LFS rules for cybaash.github.io
#
# NOTE: Git LFS is NO LONGER NEEDED for the data files.
# The original data.json (~11 MB) required LFS to avoid GitHub's 100 MB push limit.
# It has been split into 5 files, each under 3.5 MB — all well within GitHub's
# normal 100 MB per-file limit and the 50 MB soft-warning threshold.
#
# If you ever regenerate a single combined data.json larger than ~50 MB,
# re-enable LFS by uncommenting the line below and running:
#   git lfs install && git lfs track "portfolio/data.json"
#
# portfolio/data.json   filter=lfs diff=lfs merge=lfs -text   ← disabled

# ── Text normalisation (line endings) ────────────────────────────────────────
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.py        text eol=lf
*.sh        text eol=lf

# ── Binary files (no diff, no merge) ─────────────────────────────────────────
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.woff      binary
*.woff2     binary
